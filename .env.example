# Supabase Postgres (enable pgvector extension in SQL editor)
# Put secrets in `.env` or `.env.local` (local overrides — Next.js convention)
# Pooler — runtime API + worker (transaction mode, port 6543)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
# Direct — db:push / migrations only (port 5432). Optional local runtime fallback if pooler DNS fails.
DATABASE_URL_DIRECT=postgresql://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres
# Worker — optional separate URL. Leave EMPTY locally unless you know direct 5432 works.
# Direct (db.*.supabase.co:5432) often fails from home networks with CONNECT_TIMEOUT.
# If worker can't connect, remove this line and use DATABASE_URL (pooler) for everything.
DATABASE_URL_WORKER=
# Max connections per process (API + worker each open a pool; keep low on free Supabase tier)
DATABASE_POOL_MAX=2
DATABASE_CONNECT_TIMEOUT_S=30
# Force runtime to use db.*.supabase.co direct (not recommended locally)
CLEARANCE_ALLOW_DIRECT_DB=false

# Alibaba OSS — knowledge file uploads (hackathon submission API proof)
OSS_REGION=oss-ap-southeast-1
OSS_BUCKET=clearance-knowledge
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_ENDPOINT=https://oss-ap-southeast-1.aliyuncs.com

# AgentMail (per-org inbox created in onboarding)
AGENTMAIL_API_KEY=
# Local dev: worker uses WebSockets automatically when WEBHOOK_URL is unset (no ngrok)
AGENTMAIL_USE_WEBSOCKET=true
# Production only — public URL pointing at POST /webhooks/agentmail on Alibaba API
AGENTMAIL_WEBHOOK_URL=
# From AgentMail console or auto-register response (starts with whsec_)
AGENTMAIL_WEBHOOK_SECRET=
# Platform key for Clearance backend only — not per-user inbox id
# Each org stores agentmail_inbox_id in DB after onboarding step 2

# Qwen Cloud API key — required for real AI; leave empty for stub/demo mode
# Get from hackathon credits / https://dashscope.console.aliyun.com
# Also accepts DASHSCOPE_API_KEY (same value, legacy alias)
QWEN_CLOUD_API_KEY=
QWEN_MODEL=qwen-plus
# Hackathon keys use the intl endpoint by default; override only if needed
# QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Embeddings for knowledge RAG (dashscope | local)
EMBEDDING_PROVIDER=dashscope
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSIONS=1024
EMBEDDING_BATCH_SIZE=10

# App URLs
API_URL=http://localhost:3001
WEB_URL=http://localhost:3000
# Vercel frontend — points at Alibaba backend in production
NEXT_PUBLIC_API_URL=http://localhost:3001

# Clerk auth (Phase 5)
# Web app requires NEXT_PUBLIC_ prefix; API uses CLERK_SECRET_KEY.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Optional audience check for token verification
CLERK_AUDIENCE=

# Mock services (local dev only)
TICKET_API_URL=http://localhost:4001
IDP_API_URL=http://localhost:4002
NOTIFY_API_URL=http://localhost:4003

# Worker (local dev polling; prod runs on Alibaba alongside API)
WORKER_POLL_MS=2000
WORKER_REPAIR_POLL_MS=30000
WORKER_POLL_STARTUP_DELAY_MS=5000
# AgentMail inbox sync fallback when WebSocket misses a message (ms)
AGENTMAIL_SYNC_POLL_MS=15000
AGENTMAIL_SYNC_STARTUP_DELAY_MS=5000
AUTOPILOT_REPAIR_BATCH_LIMIT=25
# Set true only if the worker is not running (default: ingest runs on worker)
AGENTMAIL_INGEST_ON_API=false
# Sync on every GET /threads (off by default — worker + POST /agentmail/sync handle ingest)
AGENTMAIL_SYNC_ON_READ=false
